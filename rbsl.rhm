#lang rhombus

import :
  rhombus/meta open

export:
  //#{#%module-begin}
  all_from(rhombus):// might have to change the all here
    except: #%module_block
            def
            fun
            :: // check
  rename:
    module_block as #%module_block
    let as define
    math.pi as pi
  function
  expt
  random
  ceiling
  //to_string // check if this is the same as string=?
  sqr
  
// for stuff like string=? just use ==
// for methods just define a rkt helper module
// write functions unless you need to use a macro
decl.macro 'module_block: $form; ...':

  def ls = [form, ...]
  
  // check the binding of check_expect
  fun non_check_exprs(ls):
    match ls
    | [] : []
    | ['check_expect($a, $b)', rest, ...] : non_check_exprs([rest, ...])
    | [a, b, ...] : [a] ++ non_check_exprs([b, ...])

  fun check_exprs(ls):
    match ls
    | [] : []
    | ['check_expect($a, $b)', rest, ...] : ['check_expect($a, $b)'] ++ check_exprs([rest, ...])
    | [a, b, ...] : check_exprs([b, ...])

  // print(check_exprs(ls) ++ [1+]) eval so we can do everything else? 
  def check_forms = check_exprs(ls)
  def num_of_checks = check_forms.length()
  def check_message = to_string(num_of_checks) ++ " of " ++ to_string(num_of_checks) ++ " tests run"
  def [x, ...] = non_check_exprs(ls) ++ check_exprs(ls)

// add a print at the end of module_block if you have more than 0 checks 
// if number of tests > 0 and all of them pass then this is fine (fix va)
// else if # of tests > 0 but not all pass -> error message?
// else dont print anything
  if num_of_checks > 0
  | '#%module_block:
       $x
       ...
       println($check_message)
     '
  | def [x, ...] = non_check_exprs(ls) ++ check_exprs(ls)
    '#%module_block:
       $x
       ...'
    

decl.macro
| 'let $(x :: Identifier) = $(y :: Group)' :
    'def $x = $y'
| 'let $(x :: Identifier) = ' :
    'error(~who : #'define, " missing body when defining a variable")'   
| 'let $(x :: Identifier) : $(y :: Group)' :
    'error(~who : #'define, "can't use : in place of = when defining a variable")'
// missing body, x is not an id, multiple bodies and all of the above plus : returns an error
// ask about : error when returning an empty body

decl.macro 
| 'function $(fun_id :: Identifier)($(arg :: Identifier), ...) : $(body :: Group)' :
    'fun $fun_id($arg, ...) : $body '
| 'function $(fun_id :: Identifier)($(arg :: Identifier), ...) = $(body :: Group)' :
    'error(~who : #'$fun_id, "can't use = in place of : when defining a function")'
// fun_id not an identifier or an arg is not identifier

// fix some of these cases
// add checking for bound ids
// ask about id || num

// def is gonna expand to a macro that does the checking and a function
expr.macro
| 'expt($(x :: Identifier), $(y :: Identifier))' : 'math.expt($x, $y)'
| 'expt($(x :: Number), $(y :: Identifier))' : 'math.expt($x, $y)'
| 'expt($(x :: Identifier), $(y :: Number))' : 'math.expt($x, $y)'
| 'expt($(x :: Number), $(y :: Number))' : 'math.expt($x, $y)'
| 'expt($w, $x , $y, $z, ...)' : def ls = [w, x, y, z, ...].length()
                                 'error(~who : #'expt, "expects only 2 arguments, but found " ++ Syntax.to_source_string('$ls'))'
| 'expt($(x :: Number), $y)' : 'error(~who : #'expt, "expects a number, given " ++ Syntax.to_source_string('$y'))'
| 'expt($x, $(y :: Number))' : 'error(~who : #'expt, "expects a number, given " ++ Syntax.to_source_string('$x'))'
| 'expt($x)' : 'error(~who : #'expt, "expected 2 arguments but found only 1")'
| 'expt()' : 'error(~who : #'expt, "expected 2 arguments but found none")'
| 'expt' : 'error(~who : #'expt, "expected a function call")'

expr.macro
| 'random($(x :: Identifier))' : 'math.random($x)'
| 'random($(x :: Number))' : 'math.random($x)'
| 'random($x , $y, $z, ...)' : def ls = [x, y, z, ...].length()
                               'error(~who : #'random, "expects only 1 argument, but found " ++ Syntax.to_source_string('$ls'))'
| 'random($x)' : 'error(~who : #'random, "expects a number, given " ++ Syntax.to_source_string('$x'))'
| 'random()' : 'error(~who : #'random, "expected 1 argument but found none")'
| 'random' : 'error(~who : #'random, "expected a function call")'

expr.macro
| 'ceiling($(x :: Identifier))' : 'math.ceiling($x)'
| 'ceiling($(x :: Number))' : 'math.ceiling($x)'
| 'ceiling($x , $y, $z, ...)' : def ls = [x, y, z, ...].length()
                                'error(~who : #'ceiling, "expects only 1 argument, but found " ++ Syntax.to_source_string('$ls'))'
| 'ceiling($x)' : 'error(~who : #'ceiling, "expects a number, given " ++ Syntax.to_source_string('$x'))'
| 'ceiling()' : 'error(~who : #'ceiling, "expected 1 argument but found none")'
| 'ceiling' : 'error(~who : #'ceiling, "expected a function call")'


function check_expect(expr, expected):
  if expr is_a Number && expected is_a Number
  | if math.equal(expr, expected)
    | check expr ~is expr
    | check expr ~is expected
  | check expr ~is expected

function sqr(x):
  x * x
