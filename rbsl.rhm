fun sniptopict(image,fun_id = "fun", index ="1st"):
  if image is_a p.Pict
  | image
  | if to_string(image) in {"object:image-snip%(#'#{...}, #'#{...})",
                            "object:pict-snip%(#'#{...}, #'#{...})"}
    | def file_name = to_string(Symbol.gen("image")) ++ ".png"
      savesnip(pict.to_bitmap(topict(image)), file_name)
      def img = p.bitmap(file_name)
      filesystem.delete(file_name)
      img
    | error(~who: to_string(fun_id),
            "expects a picture as " ++ index ++ " argument",
            ~details: ["given:",image])
      
